# =============================================================================
# NEXUS Backend Environment Configuration
# =============================================================================
# DO NOT COMMIT THIS FILE! Copy to .env and fill in your actual values.
# Use strong, unique values for production secrets.
# =============================================================================

# Server Configuration
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-production-domain.com

# Database Configuration
# -----------------------------------------------------------------------------
# For local development:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_db
DB_USER=your_username
DB_PASSWORD=your_strong_password_here

# For production (supersedes individual vars if set):
DATABASE_URL=postgresql://username:password@host:5432/nexus_db

# JWT Configuration
# -----------------------------------------------------------------------------
# Generate a strong random secret (e.g., 64+ chars from openssl rand -base64 64)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# Email Service Configuration - Resend.com
# -----------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys
# For testing: RESEND_FROM_EMAIL=NEXUS <onboarding@resend.dev>
# For production: Use your verified domain (e.g., noreply@yourdomain.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=NEXUS <noreply@yourdomain.com>

# Stripe Configuration (Credit Store)
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.stripe.com/apikeys
# Use production keys (sk_live_*) for live credit purchases
# Webhook secret from Stripe Dashboard -> Webhooks -> Signing secret
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
